class PwdCtx:
    def hash(self, secret):
        return _bcrypt.hashpw(secret.encode(), _bcrypt.gensalt()).decode()
    def verify(self, secret, hash_val):
        return _bcrypt.checkpw(secret.encode(), hash_val.encode())

pwd_ctx = PwdCtx()
security = HTTPBearer(auto_error=False)

