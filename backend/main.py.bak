        client_id=user.client_id,
        topic_id=topic_id,
        platform=data.platform or "manual",
        author_name=data.author_name,
        author_handle=data.author_handle,
        content=data.content,
        url=data.url,
        sentiment=data.sentiment,
        sentiment_score=data.sentiment_score,
        posted_at=posted,
    )
    db.add(mention)
    db.commit()
