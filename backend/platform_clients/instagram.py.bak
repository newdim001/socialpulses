from __future__ import annotations
from typing import Optional, List
import requests
import os
import logging

from platform_clients import BasePlatformClient

logger = logging.getLogger("socialpulses.platform_clients.instagram")


class InstagramClient(BasePlatformClient):
    """Instagram API client using Instagram Business Login tokens (graph.instagram.com)."""

    IG_BASE = "https://graph.instagram.com"

    def __init__(self, access_token: str, refresh_token: Optional[str] = None, ig_user_id: Optional[str] = None):
        super().__init__(access_token, refresh_token)
        self._ig_user_id = ig_user_id

    def _get_ig_user_id(self) -> str:
        if self._ig_user_id:
            return self._ig_user_id
        resp = requests.get(
            f"{self.IG_BASE}/me",
            params={"fields": "id", "access_token": self.access_token},
        )
        resp.raise_for_status()
        self._ig_user_id = resp.json()["id"]
        return self._ig_user_id

    def post_text(self, text: str) -> dict:
        """Instagram does not support text-only posts. Images (or video) are required."""
        raise Exception(
            "Instagram requires media (image/video) to publish. "
            "Text-only posts are not supported. Please add an image to your post."
        )

    def post_with_media(self, text: str, media_urls: List[str]) -> dict:
        ig_id = self._get_ig_user_id()
        if not media_urls:
            raise Exception(
                "Instagram requires media (image/video) to publish. "
                "Please add an image to your post."
            )

        image_creation_ids = []
        for url in media_urls:
            resp = requests.post(
                f"{self.IG_BASE}/{ig_id}/media",
                params={
                    "access_token": self.access_token,
                    "image_url": url,
                    "caption": text if len(image_creation_ids) == 0 else "",
                    "is_carousel_item": "true" if len(media_urls) > 1 else "false",
                },
            )
            resp.raise_for_status()
            image_creation_ids.append(resp.json()["id"])

        if len(image_creation_ids) > 1:
            carousel_resp = requests.post(
                f"{self.IG_BASE}/{ig_id}/media",
                params={
                    "access_token": self.access_token,
                    "media_type": "CAROUSEL",
                    "children": ",".join(image_creation_ids),
                    "caption": text,
                },
            )
            carousel_resp.raise_for_status()
            creation_id = carousel_resp.json()["id"]
        else:
            creation_id = image_creation_ids[0]

        publish_resp = requests.post(
            f"{self.IG_BASE}/{ig_id}/media_publish",
            params={"access_token": self.access_token, "creation_id": creation_id},
        )
        publish_resp.raise_for_status()
        post_id = publish_resp.json()["id"]
        return {"platform_post_id": post_id, "url": f"https://instagram.com/p/{post_id}"}

    def get_user_info(self) -> dict:
        resp = requests.get(
            f"{self.IG_BASE}/me",
            params={"fields": "id,username,name", "access_token": self.access_token},
        )
        resp.raise_for_status()
        data = resp.json()
        return {
            "platform_user_id": data["id"],
            "platform_username": data.get("username", data["id"]),
            "display_name": data.get("name", data.get("username", data["id"])),
        }

    def refresh_access_token(self) -> Optional[str]:
        client_secret = os.environ.get("INSTAGRAM_CLIENT_SECRET", "") or os.environ.get("FACEBOOK_CLIENT_SECRET", "")
        if not client_secret:
            return None
        resp = requests.get(f"{self.IG_BASE}/access_token", params={
            "grant_type": "ig_exchange_token",
            "access_token": self.access_token,
            "client_secret": client_secret,
        })
        if resp.status_code != 200:
            return None
        result = resp.json()
        self.access_token = result.get("access_token", self.access_token)
        return self.access_token

    def validate_token(self) -> bool:
        try:
            self.get_user_info()
            return True
        except Exception:
            return False
