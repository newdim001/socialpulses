@app.post("/api/rss-feeds/{feed_id}/fetch")
def fetch_rss_feed(feed_id: int, user=Depends(get_current_user), db=Depends(get_db)):
    import feedparser
    feed = db.query(RssFeed).filter(RssFeed.id == feed_id, RssFeed.client_id == user.client_id).first()
    if not feed:
        raise HTTPException(404, "Feed not found")
    parsed = feedparser.parse(feed.url)
    count = 0
    for entry in parsed.entries:
        guid = entry.get("id", entry.get("link", ""))
        if not guid:
            continue
        existing = db.query(RssFeedItem).filter(RssFeedItem.guid == guid).first()
        if existing:
            continue
        item = RssFeedItem(
            feed_id=feed.id,
            title=entry.get("title", ""),
            link=entry.get("link", ""),
            description=entry.get("description", entry.get("summary", "")),
            pub_date=None,
            guid=guid,
        )
        if hasattr(entry, "published_parsed") and entry.published_parsed:
            import time
            item.pub_date = datetime.datetime.fromtimestamp(time.mktime(entry.published_parsed))
        db.add(item)
        count += 1
    feed.last_fetched_at = datetime.datetime.utcnow()
    db.commit()
    return {"fetched": count}
@app.get("/api/rss-feeds/{feed_id}/items", response_model=list[RssFeedItemOut])
