# SocialPulses Backend Configuration
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/socialpulses

# Redis
REDIS_URL=redis://localhost:6379

# Auth
APP_SECRET=your-secret-key-here
JWT_EXPIRY_HOURS=24

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://api.yourdomain.com/api/auth/google/callback

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# AI
DEEPSEEK_API_KEY=your-deepseek-key
# Or use OPENAI_API_KEY for OpenAI provider

# Resend (Email)
RESEND_API_KEY=re_...

# Public URLs
PUBLIC_URL=https://app.yourdomain.com
API_URL=https://api.yourdomain.com

# Social Platform Credentials (set via Settings UI)
# PINTEREST_APP_ID, PINTEREST_CLIENT_ID, PINTEREST_CLIENT_SECRET, etc.
