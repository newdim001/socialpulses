{
  "name": "socialpulses-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run supply-chain-safety && vite build",
    "lint": "eslint .",
    "supply-chain-safety": "node scripts/supply-chain-safety.mjs",
    "postinstall": "npm run supply-chain-safety",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:component": "vitest run",
    "test:component:watch": "vitest",
    "test:visual": "npx playwright test --config playwright.config.ts tests/e2e/visual-regression.spec.ts",
    "test:visual:update": "npx playwright test --config playwright.config.ts tests/e2e/visual-regression.spec.ts --update-snapshots",
    "test:load": "k6 run tests/load/login-flow.js",
    "test:review": "npx playwright test --config playwright.config.ts tests/e2e/visual-review.spec.ts",
    "test:review:report": "node scripts/visual-review-report.js",
    "test:review:open": "open tests/reports/visual-review.html"
  },
